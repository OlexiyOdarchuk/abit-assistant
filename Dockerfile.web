# Web app (JSON API + embedded Svelte SPA). Build with:
#   docker build -f Dockerfile.web -t abit-web .
# Serves on $HTTP_ADDR (default :8080); the host maps the domain to it.
#
# --- stage 1: build ---------------------------------------------------------
FROM golang:1.26.3-alpine AS build

RUN apk add --no-cache tzdata

ARG VERSION=dev
ARG TARGETOS=linux
ARG TARGETARCH=amd64

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=0 \
    GOOS=$TARGETOS \
    GOARCH=$TARGETARCH

# cmd/web embeds internal/web/dist (the built SPA is committed to the repo),
# so no Node/npm step is needed here.
RUN go build \
    -trimpath \
    -ldflags="-s -w -X main.version=${VERSION}" \
    -o /out/web \
    ./cmd/web

# --- stage 2: runtime -------------------------------------------------------
FROM scratch

COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=build /usr/share/zoneinfo /usr/share/zoneinfo
COPY --from=build /out/web /web

USER 65532:65532

# Bind to all interfaces on 8080 so the platform can route the domain in.
ENV HTTP_ADDR=:8080
EXPOSE 8080

# Required env: DATABASE_URL (postgres://…). Optional: LOG_LEVEL.
ENTRYPOINT ["/web"]

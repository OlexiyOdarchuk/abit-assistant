# AbitAssistant — приклад конфігурації.
# Скопіюй у .env (`cp .env.example .env`) і заповни значення.
# Файл .env у git ігнорується.

# ─── Telegram ────────────────────────────────────────────────────────────
# Токен бота від @BotFather. Обов'язково.
TELEGRAM_TOKEN=your_token_here

# Список TelegramID адміністраторів через кому. Не обов'язково.
# Адміни матимуть доступ до /admin команд (broadcast, stats, refresh).
ADMIN_IDS=

# ─── Persistence ─────────────────────────────────────────────────────────
# Шлях до SQLite-файла. Якщо не задано — резолвиться так:
#   1. legacy: якщо в cwd є ./data/abit.db — береться він (існуючі інстали)
#   2. XDG:    $XDG_DATA_HOME/abit-assistant/abit.db
#   3. home:   $HOME/.local/share/abit-assistant/abit.db
# Для Docker compose — поверни і встанови /data/abit.db (compose сам це робить).
# Спецзначення ":memory:" — ефемерна БД у памʼяті (тільки для розробки).
# DATABASE_PATH=

# ─── Logging ─────────────────────────────────────────────────────────────
# Рівень: debug | info | warn | error. Дефолт: info.
LOG_LEVEL=info

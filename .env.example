# AbitAssistant — приклад конфігурації.
# Скопіюй у .env (`cp .env.example .env`) і заповни значення.
# Файл .env у git ігнорується.

# ─── Telegram ────────────────────────────────────────────────────────────
# Токен бота від @BotFather. Обов'язково.
TELEGRAM_TOKEN=your_token_here

# Список TelegramID адміністраторів через кому. Не обов'язково.
# Адміни матимуть доступ до /admin команд (broadcast, stats, refresh).
ADMIN_IDS=

# ─── Persistence (PostgreSQL) ────────────────────────────────────────────
# Connection URL до Postgres. ОБОВ'ЯЗКОВО (дефолту немає — без нього застосунок
# явно падає, а не мовчки лізе в localhost). На хостингу встав те, що дає
# керована БД. Локально через docker compose це задається автоматично (сервіс
# postgres). Схема створюється сама на старті (міграції); БД може бути порожня.
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# ─── Logging ─────────────────────────────────────────────────────────────
# Рівень: debug | info | warn | error. Дефолт: info.
LOG_LEVEL=info
